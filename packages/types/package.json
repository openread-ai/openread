{
  "name": "@openread/types",
  "version": "0.1.0",
  "description": "Shared TypeScript types for the OpenRead platform",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run"
  },
  "devDependencies": {
    "@openread/tsconfig": "workspace:*",
    "typescript": "^5",
    "vitest": "^4.0.15"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/openread-ai/platform.git",
    "directory": "packages/types"
  },
  "keywords": [
    "openread",
    "types",
    "typescript",
    "ebook"
  ]
}
